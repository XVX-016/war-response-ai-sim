# ── ResilienceSim v1 ── .env.example ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real keys.

# Anthropic API key — only needed for ai_narrator (optional)
ANTHROPIC_API_KEY=your_key_here

# Set to "true" to skip narrator API calls during dev/testing
DISABLE_NARRATOR=false

# Set to "true" to use pretrained YOLOv8 instead of fine-tuned weights
USE_PRETRAINED_YOLO=true
